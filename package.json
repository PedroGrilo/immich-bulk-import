{
  "name": "immich-gui",
  "version": "0.1.0",
  "description": "A beautiful macOS GUI for the Immich CLI",
  "main": "dist-electron/main.js",
  "type": "module",
  "author": "Pedro Grilo",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "package": "npm run build && electron-builder --mac --config electron-builder.yml",
    "package:dir": "npm run build && electron-builder --mac --dir --config electron-builder.yml"
  },
  "dependencies": {
    "@immich/cli": "^2.2.85",
    "electron-store": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",  
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
